# Deepseek API Configuration
DEEPSEEK_API_KEY=

DEEPSEEK_MODEL=deepseek-chat

# CrewAI Settings
CREWAI_LLM_MODEL=deepseek-chat
CREWAI_VERBOSE=true

# Log Analysis Parameters
LOG_SOURCE_PATH=./data/sample_logs
MAX_LOGS_TO_ANALYZE=1000
THREAT_LEVEL_THRESHOLD=medium

# Report Settings
REPORT_OUTPUT_FORMAT=markdown
ENABLE_EMAIL_ALERTS=false
ALERT_EMAIL=admin@example.com
